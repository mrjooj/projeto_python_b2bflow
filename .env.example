# ============================================
# SUPABASE
# ============================================

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sua_chave_anon_ou_service_role_aqui

# Nome da tabela onde os contatos estão cadastrados
SUPABASE_TABLE=contatos

# ============================================
# Z-API
# ============================================

ZAPI_INSTANCE_ID=sua_instance_id
ZAPI_TOKEN=seu_token
ZAPI_CLIENT_TOKEN=seu_client_token_de_seguranca

# Quantos segundos o WhatsApp mostra "digitando..." antes da mensagem chegar (1 a 15)
ZAPI_DELAY_TYPING=3

# Quantos segundos a Z-API espera antes de entregar a mensagem (1 a 15)
ZAPI_DELAY_MESSAGE=2

# ============================================
# CONFIGURAÇÕES GERAIS
# ============================================
# Quantidade máxima de contatos que serão notificados por execução
MAX_CONTATOS=3

# Intervalo aleatório (em segundos) entre o envio para um contato e o próximo,
# para não parecer um disparo em massa instantâneo.
INTERVALO_MIN_SEGUNDOS=3
INTERVALO_MAX_SEGUNDOS=8
